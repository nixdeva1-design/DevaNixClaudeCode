# CuiperConfig.env — centrale configuratie voor alle CuiperHive modules
# Gebruik: source "$(git rev-parse --show-toplevel)/CuiperConfig.env"
# Klantspecifieke override: maak CuiperConfig.local.env (niet gecommit)
#
# /dev/null verbod: fouten worden gelogd, nooit stil geslikt

_CUIPER_SELF="${BASH_SOURCE[0]:-$0}"
_CUIPER_DIR="$(cd "$(dirname "$_CUIPER_SELF")" 2>/dev/null && pwd)"

CUIPER_REPO_ERR=""
if ! CUIPER_REPO=$(git -C "$_CUIPER_DIR" rev-parse --show-toplevel 2>&1); then
    CUIPER_REPO_ERR="$CUIPER_REPO"
    CUIPER_REPO="$_CUIPER_DIR"
    echo "CUIPER FOUT [CuiperConfig]: git rev-parse mislukt: $CUIPER_REPO_ERR" >&2
fi

CUIPER_BRANCH_ERR=""
if ! CUIPER_BRANCH=$(git -C "$CUIPER_REPO" branch --show-current 2>&1); then
    CUIPER_BRANCH_ERR="$CUIPER_BRANCH"
    CUIPER_BRANCH="onbekend"
    echo "CUIPER FOUT [CuiperConfig]: branch onbekend: $CUIPER_BRANCH_ERR" >&2
fi

# ─── Klantidentiteit — overschrijfbaar per klant ──────────────────────────
CUIPER_NAMESPACE="${CUIPER_NAMESPACE:-standaard}"
CUIPER_CLIENT_ID="${CUIPER_CLIENT_ID:-standaard}"

# ─── Paden — alles relatief aan CUIPER_REPO ───────────────────────────────
CUIPER_TRAIL_DIR="$CUIPER_REPO/logs/trail"
CUIPER_BACKLOG_DIR="$CUIPER_REPO/backlog"
CUIPER_SCRIPTS_DIR="$CUIPER_REPO/scripts"
CUIPER_LOG_DIR="$CUIPER_REPO/logs"
CUIPER_JAEGER_OTLP_URL="${CUIPER_JAEGER_OTLP_URL:-http://127.0.0.1:4318}"

# ─── Lokale klant-override — NIET gecommit, staat in .gitignore ───────────
if [ -f "$CUIPER_REPO/CuiperConfig.local.env" ]; then
    # shellcheck disable=SC1090
    source "$CUIPER_REPO/CuiperConfig.local.env"
fi

unset _CUIPER_SELF _CUIPER_DIR
